{
  "name": "one_for_the_city",
  "version": "0.3.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply oneforthecity --local",
    "db:migrate:remote": "wrangler d1 migrations apply oneforthecity --remote",
    "start": "node .output/server/index.mjs",
    "test": "vitest run",
    "lint": "oxlint .",
    "fmt": "oxfmt",
    "wrangler": "wrangler",
    "drizzle": "drizzle-kit",
    "dev:stripe": "stripe listen --forward-to localhost:3000/store/webhook/stripe",
    "prod:secrets": "wrangler secret bulk .env.wrangler-secrets"
  },
  "dependencies": {
    "@headlessui/react": "^2.2.10",
    "@headlessui/tailwindcss": "^0.2.2",
    "@tanstack/react-router": "^1.170.15",
    "@tanstack/react-start": "^1.168.25",
    "@unpic/react": "^1.0.2",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^1.18.0",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "sonner": "^2.0.7",
    "stripe": "^22.2.1",
    "tabler-icons-react": "^1.56.0",
    "tailwind-merge": "^3.6.0",
    "tanstack-router-ga4": "^1.6.0",
    "typescript": "^6.0.3",
    "use-shopping-cart": "4.0.0-rc.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.40.2",
    "@fontsource-variable/dm-sans": "^5.2.8",
    "@fontsource-variable/inter": "^5.2.8",
    "@tailwindcss/vite": "^4.3.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.9.3",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "better-sqlite3": "^12.10.1",
    "concurrently": "^10.0.3",
    "drizzle-kit": "^0.31.10",
    "oxfmt": "^0.45.0",
    "oxlint": "^1.69.0",
    "tailwindcss": "^4.3.1",
    "vite": "^8.0.16",
    "vite-plugin-svgr": "^5.2.0",
    "vitest": "^4.1.8",
    "wrangler": "^4.100.0"
  },
  "browserslist": "defaults, not ie <= 11"
}
